{
  "name": "@narrative/engine",
  "version": "0.1.0",
  "private": true,
  "description": "Shared Narrative Engine core — pure TypeScript game logic consumed by the desktop (mainApp) and mobile (mobileApp) shells.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "pretest": "node scripts/boundary-gate.mjs",
    "test": "vitest run",
    "prepare": "npm run build"
  },
  "devDependencies": {
    "typescript": "~5.9.3",
    "vitest": "^4.1.5"
  }
}
